	<!-- 캐시 생성 경로 -->
	<!--<persistence directory="cache/data" />-->

	<cache-template name="defaultTemplate">
		<expiry>
			<ttl unit="seconds">1800</ttl>
		</expiry>
		<resources>
			<heap unit="entries">50</heap>
		</resources>
		<!-- 로그 -->
